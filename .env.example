# Copy to .env and fill in real values.
# DO NOT commit .env to git.

# Frappe / ERPNext base URL (no trailing slash)
API_BASE_URL=https://erp.blackbuilding.com

# Optional: API key/secret for service-account flows (leave empty for password login)
API_KEY=
API_SECRET=

# App environment: dev | staging | prod
APP_ENV=dev

# Office GPS center for check-in geo-fence (optional)
OFFICE_LATITUDE=11.0168
OFFICE_LONGITUDE=76.9558
OFFICE_RADIUS_METERS=200
